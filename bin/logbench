#!/bin/bash
set -euo pipefail

LIBEXEC="$(cd "$(dirname "$0")/../libexec" && pwd)"
HOMEBREW_PREFIX="$(cd "$(dirname "$0")/.." && pwd)"

# Ensure Homebrew binaries (bun, sqlite3) are in PATH for launchd
export PATH="${HOMEBREW_PREFIX}/bin:${PATH}"

# Data directory for persistent state
LOGBENCH_DATA="${LOGBENCH_DATA:-${XDG_DATA_HOME:-$HOME/.local/share}/logbench}"
export PORT="${LOGBENCH_PORT:-${PORT:-1447}}"
export DATABASE_URL="${DATABASE_URL:-file:${LOGBENCH_DATA}/logbench.db}"

mkdir -p "$LOGBENCH_DATA"

cd "$LIBEXEC"
exec bun run .output/server/index.mjs

{
  "name": "logbench",
  "version": "0.1.7",
  "author": "Albin Groen",
  "description": " A local log drain for people tired of console.log",
  "type": "module",
  "scripts": {
    "dev": "bun --bun vite dev --port 1447",
    "build": "bun --bun vite build",
    "preview": "bun --bun vite preview --port 1447",
    "start": "PORT=1447 bun run .output/server/index.mjs",
    "test": "vitest run",
    "lint": "eslint",
    "format": "prettier --write .",
    "check": "prettier --write . && eslint --fix",
    "check:ts": "tsc --noEmit",
    "knip": "knip"
  },
  "dependencies": {
    "@fontsource-variable/inter": "^5.2.8",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@prisma/adapter-libsql": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "@remixicon/react": "^4.9.0",
    "@tailwindcss/vite": "^4.0.6",
    "@tanstack/react-form": "^1.28.4",
    "@tanstack/react-hotkeys": "^0.3.0",
    "@tanstack/react-query": "^5.90.21",
    "@tanstack/react-router": "^1.132.0",
    "@tanstack/react-start": "^1.132.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/router-plugin": "^1.132.0",
    "@visual-json/core": "^0.1.0",
    "@visual-json/react": "^0.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.3.1",
    "launch-editor": "^2.13.1",
    "mark.js": "^8.11.1",
    "next-themes": "^0.4.6",
    "nitro": "latest",
    "radix-ui": "^1.4.3",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "shadcn": "^3.8.5",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.0.6",
    "tw-animate-css": "^1.4.0",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tanstack/eslint-config": "^0.3.0",
    "@types/mark.js": "^8.11.12",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.0.4",
    "jsdom": "^27.0.0",
    "knip": "^5.87.0",
    "prettier": "^3.5.3",
    "prisma": "^7.4.2",
    "shiki": "^4.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vitest": "^3.0.5",
    "web-vitals": "^5.1.0"
  }
